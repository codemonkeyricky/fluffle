{
  "name": "file_write",
  "description": "Write content to a file",
  "parameters": {
    "type": "object",
    "properties": {
      "path": {
        "type": "string",
        "description": "Relative path to the file to write (must be relative, not absolute)"
      },
      "content": {
        "type": "string",
        "description": "Content to write to the file"
      }
    },
    "required": ["path", "content"]
  },
  "execution": {
    "type": "bash",
    "command_template": "printf '%s' '{{content}}' > {{path}}"
  },
  "secure_parameters": ["path"]
}