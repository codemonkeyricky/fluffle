{
  "name": "echo_tool",
  "description": "Echoes the input text",
  "parameters": {
    "type": "object",
    "properties": {
      "text": {
        "type": "string",
        "description": "Text to echo"
      }
    },
    "required": ["text"]
  },
  "execution": {
    "type": "bash",
    "command_template": "echo {{text}}"
  }
}
