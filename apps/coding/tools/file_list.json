{
  "name": "file_list",
  "description": "List files in a directory",
  "parameters": {
    "type": "object",
    "properties": {
      "path": {
        "type": "string",
        "description": "Path to the directory to list (default: current directory)",
        "default": "."
      }
    },
    "required": []
  },
  "execution": {
    "type": "bash",
    "command_template": "ls -la {{path}}"
  },
  "secure_parameters": ["path"]
}