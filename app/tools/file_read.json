{
  "name": "file_read",
  "description": "Read the contents of a file",
  "parameters": {
    "type": "object",
    "properties": {
      "path": {
        "type": "string",
        "description": "Path to the file to read"
      }
    },
    "required": ["path"]
  },
  "execution": {
    "type": "bash",
    "command_template": "cat {{path}}"
  },
  "secure_parameters": ["path"]
}